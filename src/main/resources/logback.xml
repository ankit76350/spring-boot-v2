<configuration>

    <appender name="myConsoleAppender" class="ch.qos.logback.core.ConsoleAppender">
        <!-- WRONG: class= "ch.qos.logback.core.ConsoleAppnder"  — typo: "Appnder" should be "Appender" -->
        <!-- WRONG: missing <encoder> — without it, logback has no format and prints nothing -->
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-50level %logger{36} ---- %msg %n</pattern>
        </encoder>
    </appender>

    <appender name="myFileAppender" class="ch.qos.logback.core.rolling.RollingFileAppender">
         <file>
        JournalAppDemo.log
        </file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>JournalApp-%d{yy-MM-dd_HH-mm}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <!-- WRONG: <maxHistory>10MB</maxHistory> — maxHistory takes a number (days/files), not a size like "10MB" -->
            <maxHistory>10</maxHistory> <!-- Keep last 10 archived log files -->
            
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
   
    </appender>

    <root level="INFO">
        <appender-ref ref="myConsoleAppender"/>
        <appender-ref ref="myFileAppender"/>
    </root>

</configuration>
